---
import { Image } from 'astro:assets';
import emblemCream from '../assets/images/emblem-cream.svg';
import { GIVE_URL, CLASSREACH_URL } from '../lib/links';

const navItems = [
	{ marker: 'I.',    label: 'Our Vision',   href: '/our-vision' },
	{ marker: 'II.',   label: 'How It Works', href: '/how-it-works' },
	{ marker: 'III.',  label: 'People',       href: '/people' },
	{ marker: 'IV.',   label: 'Admissions',   href: '/admissions' },
	{ marker: 'V.',    label: 'Give',         href: GIVE_URL },
];

// Secondary destinations for current and prospective families. Lives
// under MENU in the footer's column 4 so it doesn't compete with the
// primary 5-item Roman-numeral nav. Add future items (e.g. Parent Portal,
// Calendar, Newsletter Archive) here as the school's needs grow.
const familyItems = [
	{ label: 'Resources', href: '/resources' },
	{ label: 'FAQ',       href: '/faq' },
	{ label: 'Careers',   href: '/careers' },
];
---

<!-- ====== SECTION 6 — Footer ====== -->
<footer aria-label="Site footer" class="bg-racing text-white font-sans">
	<div class="relative mx-auto w-full max-w-canvas px-6 pb-8 pt-20 sm:px-10 lg:px-12">
		<!-- Page-wide vertical column dividers continuing through the footer.
		     Same 25% / 50% / 75% positions as the main page layer in
		     `index.astro`, but at a cream tint so they're visible on the
		     dark green background. -->
		<div
			class="pointer-events-none absolute inset-0 z-0 hidden lg:block lg:px-12"
			aria-hidden="true"
		>
			<div class="relative h-full">
				<div class="absolute inset-y-0 left-1/4 w-px bg-white/[0.06]"></div>
				<div class="absolute inset-y-0 left-1/2 w-px bg-white/[0.06]"></div>
				<div class="absolute inset-y-0 left-3/4 w-px bg-white/[0.06]"></div>
			</div>
		</div>

		<!-- Zone A — top content row.
		     4-column grid on lg+ aligned to the page-wide 25/50/75% divider
		     lines. Col 1 (emblem + mission) spans cols 1-2, the address/
		     get-in-touch stack sits in col 3, and MENU sits in col 4. On < lg
		     everything stacks vertically in a single column. -->
		<div class="relative z-10 grid grid-cols-1 gap-12 lg:grid-cols-4 lg:gap-0">

			<!-- Col 1-2: TRINITY logotype + italic mission paragraph -->
			<div class="flex flex-col gap-8 lg:col-span-2 lg:pr-8">
				<a href="/" aria-label="Trinity Classical Academy" class="self-start">
					<Image
						src={emblemCream}
						alt=""
						class="h-12 w-auto"
					/>
				</a>

				<!-- Mission paragraph: only the school name is italic -->
				<p class="max-w-[560px] font-display text-[28px] leading-[0.95] text-white sm:text-[40px]">
					<em class="italic">Trinity Classical Academy</em> partners with
					families in the joyful discipleship of students through rigorous,
					Christ-centered classical education.
				</p>
			</div>

			<!-- Col 3: OUR SCHOOL + MENU stacked.
			     Left side groups static facts about the school — the physical
			     address and the primary 5-item Roman-numeral nav recap. -->
			<div class="flex flex-col gap-10 lg:px-8">
				<!-- OUR SCHOOL -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						OUR SCHOOL
					</h2>
					<address class="font-mono text-sm not-italic leading-snug text-white">
						7160 Cahaba Valley Rd.<br />
						Birmingham, AL<br />
						35242
					</address>
				</div>

				<!-- MENU -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						MENU
					</h2>
					<nav aria-label="Footer">
						<ol class="flex flex-col gap-2">
							{navItems.map((item) => (
								<li class="flex items-baseline gap-3">
									<span class="w-6 font-mono text-[10px] text-gold">
										{item.marker}
									</span>
									<a
										href={item.href}
										class="font-sans text-sm text-white transition hover:opacity-70"
									>
										{item.label}
									</a>
								</li>
							))}
						</ol>
					</nav>
				</div>
			</div>

			<!-- Col 4: GET IN TOUCH + FOR FAMILIES stacked.
			     Right side groups actionable destinations — the contact
			     channels and the secondary family-resource links. Both are
			     things visitors might do, as opposed to facts to know. -->
			<div class="flex flex-col gap-10 lg:px-8">
				<!-- GET IN TOUCH -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						GET IN TOUCH
					</h2>
					<ul class="flex flex-col gap-2">
						<li>
							<a
								href="mailto:info@trinityclassical.academy"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Email
							</a>
						</li>
						<li>
							<a
								href="/contact"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Contact Us
							</a>
						</li>
						<li>
							<a
								href="https://instagram.com/trinityclassicalacademy"
								target="_blank"
								rel="noopener noreferrer"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Follow Us
							</a>
						</li>
					</ul>
				</div>

				<!-- FOR FAMILIES -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						FOR FAMILIES
					</h2>
					<nav aria-label="For families">
						<ul class="flex flex-col gap-2">
							{familyItems.map((item) => (
								<li>
									<a
										href={item.href}
										class="font-sans text-sm text-white transition hover:opacity-70"
									>
										{item.label}
									</a>
								</li>
							))}
								<li>
									<a
										href={CLASSREACH_URL}
										target="_blank"
										rel="noopener noreferrer"
										class="font-sans text-sm text-white transition hover:opacity-70"
									>
										Parent Login ↗
									</a>
								</li>
						</ul>
					</nav>
				</div>
			</div>
		</div>

		<!-- Zone B — giant TRINITY wordmark -->
		<div class="relative z-10 mt-16 overflow-hidden">
			<p class="text-wordmark font-display uppercase text-white whitespace-nowrap">
				Trinity
			</p>
		</div>

		<!-- Zone C — bottom utility row -->
		<div class="relative z-10 mt-4">
			<p class="font-mono text-xs text-white opacity-60">
				© 2026 TCA
			</p>
			<p class="mt-6 max-w-[720px] font-sans text-[10px] leading-[1.5] text-white opacity-30">
				We admit students and hire employees without regard to race, color, national origin, or ethnic origin, ensuring equal access to all rights, privileges, programs, and activities generally available to our school community. We are committed to upholding applicable nondiscriminatory policies in the administration of educational policies, admissions, scholarships, loan programs, athletics, and other school-administered activities. We do not accept federal funds.
			</p>
		</div>
	</div>
</footer>
