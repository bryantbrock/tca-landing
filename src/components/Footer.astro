---
import { Image } from 'astro:assets';
import emblemCream from '../assets/images/emblem-cream.svg';
import { GIVE_URL, CLASSREACH_URL, INTERVIEW_URL } from '../lib/links';
---

<!-- ====== SECTION 6 — Footer ====== -->
<footer aria-label="Site footer" class="bg-racing text-white font-sans">
	<div class="relative mx-auto w-full max-w-canvas px-6 pb-8 pt-20 sm:px-10 lg:px-12">
		<!-- Page-wide vertical column dividers continuing through the footer.
		     Same 25% / 50% / 75% positions as the main page layer in
		     `index.astro`, but at a cream tint so they're visible on the
		     dark green background. -->
		<div
			class="pointer-events-none absolute inset-0 z-0 hidden lg:block lg:px-12"
			aria-hidden="true"
		>
			<div class="relative h-full">
				<div class="absolute inset-y-0 left-1/4 w-px bg-white/[0.06]"></div>
				<div class="absolute inset-y-0 left-1/2 w-px bg-white/[0.06]"></div>
				<div class="absolute inset-y-0 left-3/4 w-px bg-white/[0.06]"></div>
			</div>
		</div>

		<!-- Zone A — 4-column grid aligned to 25/50/75% dividers -->
		<div class="relative z-10 grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-0">

			<!-- Column at 0%: Mission -->
			<div class="flex flex-col gap-8 lg:pr-8">
				<a href="/" aria-label="Trinity Classical Academy" class="self-start">
					<Image
						src={emblemCream}
						alt=""
						class="h-12 w-auto"
					/>
				</a>

				<p class="font-display text-[22px] leading-[0.95] text-white sm:text-[28px]">
					<em class="italic">Trinity Classical Academy</em> partners with
					families in the joyful discipleship of students through rigorous,
					Christ-centered classical education.
				</p>
			</div>

			<!-- Column at 25%: OUR SCHOOL + ABOUT -->
			<div class="flex flex-col gap-10 lg:px-8">
				<!-- OUR SCHOOL -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						Our School
					</h2>
					<address class="font-mono text-sm not-italic leading-snug text-white">
						7160 Cahaba Valley Rd.<br />
						Birmingham, AL<br />
						35242
					</address>
					<a
						href="https://trinitypresbham.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="font-sans text-sm text-white transition hover:opacity-70"
					>
						Our Church ↗
					</a>
				</div>

				<!-- ABOUT -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						About
					</h2>
					<nav aria-label="About">
						<ul class="flex flex-col gap-2">
							<li>
								<a href="/#our-vision" class="font-sans text-sm text-white transition hover:opacity-70">
									Our Vision
								</a>
							</li>
							<li>
								<a href="/#how-it-works" class="font-sans text-sm text-white transition hover:opacity-70">
									How It Works
								</a>
							</li>
							<li>
								<a href="/people" class="font-sans text-sm text-white transition hover:opacity-70">
									People
								</a>
							</li>
						</ul>
					</nav>
				</div>
			</div>

			<!-- Column 2: ADMISSIONS + FAMILIES -->
			<div class="flex flex-col gap-10 lg:px-8">
				<!-- ADMISSIONS -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						Admissions
					</h2>
					<nav aria-label="Admissions">
						<ul class="flex flex-col gap-2">
							<li>
								<a href="/admissions" class="font-sans text-sm text-white transition hover:opacity-70">
									Admissions Process
								</a>
							</li>
							<li>
								<a
									href={INTERVIEW_URL}
									target="_blank"
									rel="noopener noreferrer"
									class="font-sans text-sm text-white transition hover:opacity-70"
								>
									Request an Interview ↗
								</a>
							</li>
						</ul>
					</nav>
				</div>

				<!-- FAMILIES -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						Families
					</h2>
					<nav aria-label="Families">
						<ul class="flex flex-col gap-2">
							<li>
								<a href="/resources" class="font-sans text-sm text-white transition hover:opacity-70">
									Resources
								</a>
							</li>
							<li>
								<a href="/faq" class="font-sans text-sm text-white transition hover:opacity-70">
									FAQ
								</a>
							</li>
							<li>
								<a href="/resources/tuition" class="font-sans text-sm text-white transition hover:opacity-70">
									Tuition Policy
								</a>
							</li>
							<li>
								<a href="/resources/uniform" class="font-sans text-sm text-white transition hover:opacity-70">
									Uniform Policy
								</a>
							</li>
							<li>
								<a
									href={CLASSREACH_URL}
									target="_blank"
									rel="noopener noreferrer"
									class="font-sans text-sm text-white transition hover:opacity-70"
								>
									Parent Login ↗
								</a>
							</li>
						</ul>
					</nav>
				</div>
			</div>

			<!-- Column 3: GET IN TOUCH + GET INVOLVED -->
			<div class="flex flex-col gap-10 lg:px-8">
				<!-- GET IN TOUCH -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						Get in Touch
					</h2>
					<ul class="flex flex-col gap-2">
						<li>
							<a
								href="mailto:info@trinityclassical.academy"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Email
							</a>
						</li>
						<li>
							<a
								href="/contact"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Contact Us
							</a>
						</li>
						<li>
							<a
								href="https://www.facebook.com/profile.php?id=61582574271980"
								target="_blank"
								rel="noopener noreferrer"
								class="font-sans text-sm text-white transition hover:opacity-70"
							>
								Follow Us
							</a>
						</li>
					</ul>
				</div>

				<!-- GET INVOLVED -->
				<div class="flex flex-col gap-4">
					<h2 class="font-mono text-xs font-medium uppercase tracking-eyebrow text-gold">
						Get Involved
					</h2>
					<nav aria-label="Get involved">
						<ul class="flex flex-col gap-2">
							<li>
								<a
									href={GIVE_URL}
									target="_blank"
									rel="noopener noreferrer"
									class="font-sans text-sm text-white transition hover:opacity-70"
								>
									Give ↗
								</a>
							</li>
							<li>
								<a href="/careers" class="font-sans text-sm text-white transition hover:opacity-70">
									Careers
								</a>
							</li>
						</ul>
					</nav>
				</div>
			</div>
		</div>

		<!-- Zone B — giant TRINITY wordmark -->
		<div class="relative z-10 mt-16 overflow-hidden">
			<p class="text-wordmark font-display uppercase text-white whitespace-nowrap">
				Trinity
			</p>
		</div>

		<!-- Zone C — bottom utility row -->
		<div class="relative z-10 mt-4">
			<p class="font-mono text-xs text-white opacity-60">
				© 2026 TCA
			</p>
			<p class="mt-6 font-sans text-[10px] leading-[1.5] text-white opacity-30">
				We admit students and hire employees without regard to race, color, national origin, or ethnic origin, ensuring equal access to all rights, privileges, programs, and activities generally available to our school community. We are committed to upholding applicable nondiscriminatory policies in the administration of educational policies, admissions, scholarships, loan programs, athletics, and other school-administered activities. We do not accept federal funds.
			</p>
		</div>
	</div>
</footer>
