---
import { Image } from 'astro:assets';
import emblemInk from '../assets/images/emblem-ink.svg';
import { GIVE_URL, INTERVIEW_URL, CLASSREACH_URL } from '../lib/links';

const navCategories = [
	{
		label: 'About',
		id: 'about',
		items: [
			{ label: 'Our Vision',   href: '/our-vision' },
			{ label: 'How It Works', href: '/how-it-works' },
			{ label: 'People',       href: '/people' },
		],
	},
	{
		label: 'Admissions',
		id: 'admissions',
		items: [
			{ label: 'Admissions Process',    href: '/admissions' },
			{ label: 'Request an Interview',  href: INTERVIEW_URL, external: true },
		],
	},
	{
		label: 'Families',
		id: 'families',
		items: [
			{ label: 'Resources',       href: '/resources' },
			{ label: 'FAQ',             href: '/faq' },
			{ label: 'Tuition Policy',  href: '/resources/tuition' },
			{ label: 'Uniform Policy',  href: '/resources/uniform' },
			{ label: 'Parent Login',    href: CLASSREACH_URL, external: true },
		],
	},
	{
		label: 'Get Involved',
		id: 'get-involved',
		items: [
			{ label: 'Give',     href: GIVE_URL,   external: true },
			{ label: 'Careers',  href: '/careers' },
			{ label: 'Contact',  href: '/contact' },
		],
	},
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHomePage = currentPath === '/';
---

<header class="site-header sticky top-0 z-40 bg-transparent transition-[background-color,backdrop-filter] duration-200 ease-out">
	<div class="site-header-inner mx-auto flex w-full max-w-canvas items-center justify-between px-6 pb-7 pt-7 sm:px-10 sm:pb-8 sm:pt-8 lg:px-12 lg:pb-9 lg:pt-9">

		<!-- Left: wordmark + optional ← Home -->
		<div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-6">
			<a
				href="/"
				aria-label="Trinity Classical Academy"
				class="font-sans text-[12px] font-medium uppercase tracking-eyebrow text-ink"
			>
				Trinity Classical Academy
			</a>

			{!isHomePage && (
				<a
					href="/"
					class="group inline-flex items-center gap-1.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink-soft transition-colors hover:text-forest"
					aria-label="Back to home"
				>
					<span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
					<span>Home</span>
				</a>
			)}
		</div>

		<!-- Right: mobile toggle + nav + emblem -->
		<div class="relative flex items-center gap-4 sm:gap-6">

			<!-- Mobile menu toggle (hidden lg+) -->
			<button
				type="button"
				aria-expanded="false"
				aria-controls="primary-nav"
				class="flex items-center gap-1.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink transition-colors hover:text-forest lg:hidden"
				data-nav-toggle
			>
				<span data-nav-label>Menu</span>
				<svg
					width="10"
					height="10"
					viewBox="0 0 10 10"
					class="transition-transform duration-150 ease-out"
					data-nav-icon
					aria-hidden="true"
				>
					<path
						d="M2 3.5 L5 6.5 L8 3.5"
						stroke="currentColor"
						stroke-width="1.5"
						fill="none"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
			</button>

			<!-- Primary nav -->
			<nav
				id="primary-nav"
				aria-label="Primary"
				data-nav-panel
				data-state="closed"
				class="absolute right-0 top-full mt-3 min-w-[240px] rounded-card border border-ink/10 bg-white/95 shadow-lg backdrop-blur-md lg:relative lg:right-auto lg:top-auto lg:mt-0 lg:min-w-0 lg:rounded-none lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-none"
			>
				<!-- Desktop: horizontal category row -->
				<ul class="hidden lg:flex lg:flex-row lg:items-center lg:gap-6" data-desktop-nav>
					{navCategories.map((cat) => (
						<li class="relative" data-desktop-category data-category-id={cat.id}>
							<button
								type="button"
								aria-expanded="false"
								aria-controls={`dropdown-${cat.id}`}
								aria-haspopup="true"
								class="flex items-center gap-1 font-sans text-sm font-medium text-ink transition-colors hover:text-forest"
								data-category-trigger
							>
								<span>{cat.label}</span>
								<svg
									width="10"
									height="10"
									viewBox="0 0 10 10"
									class="transition-transform duration-150 ease-out"
									data-category-icon
									aria-hidden="true"
								>
									<path
										d="M2 3.5 L5 6.5 L8 3.5"
										stroke="currentColor"
										stroke-width="1.5"
										fill="none"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</button>
							<div
								id={`dropdown-${cat.id}`}
								role="region"
								data-dropdown
								class="absolute right-0 top-full mt-2 min-w-[180px] rounded-card border border-ink/10 bg-white/95 p-5 shadow-lg backdrop-blur-md"
							>
								<ul class="flex flex-col gap-2">
									{cat.items.map((item) => (
										<li>
											<a
												href={item.href}
												class="flex items-center gap-1.5 font-sans text-sm text-ink transition-colors hover:text-forest"
												{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
											>
												{item.label}
												{item.external && (
													<span aria-hidden="true" class="text-ink-mute">↗</span>
												)}
											</a>
										</li>
									))}
								</ul>
							</div>
						</li>
					))}
				</ul>

				<!-- Mobile: accordion category list -->
				<div class="flex flex-col lg:hidden" data-mobile-nav>
					{navCategories.map((cat) => (
						<div class="border-b border-ink/10 last:border-0" data-mobile-category>
							<button
								type="button"
								aria-expanded="false"
								aria-controls={`mobile-${cat.id}`}
								class="flex w-full items-center justify-between px-5 py-3 font-sans text-sm font-medium text-ink transition-colors hover:text-forest"
								data-mobile-trigger
							>
								<span>{cat.label}</span>
								<svg
									width="10"
									height="10"
									viewBox="0 0 10 10"
									class="transition-transform duration-150 ease-out"
									data-mobile-icon
									aria-hidden="true"
								>
									<path
										d="M2 3.5 L5 6.5 L8 3.5"
										stroke="currentColor"
										stroke-width="1.5"
										fill="none"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</button>
							<div
								id={`mobile-${cat.id}`}
								data-mobile-panel
								class="overflow-hidden"
								style="max-height: 0; transition: max-height 250ms ease-out;"
							>
								<ul class="flex flex-col gap-1 px-5 pb-3 pt-1">
									{cat.items.map((item) => (
										<li>
											<a
												href={item.href}
												class="flex items-center gap-1.5 font-sans text-sm text-ink-soft transition-colors hover:text-forest"
												{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
												data-nav-link
											>
												{item.label}
												{item.external && (
													<span aria-hidden="true" class="text-ink-mute">↗</span>
												)}
											</a>
										</li>
									))}
								</ul>
							</div>
						</div>
					))}
				</div>
			</nav>

			<!-- Emblem -->
			<a
				href="/"
				aria-label="Trinity Classical Academy"
				class="text-ink"
			>
				<Image
					src={emblemInk}
					alt=""
					class="h-9 w-auto"
				/>
			</a>
		</div>
	</div>
</header>

<style>
	/* Frosted backdrop on scroll */
	:global(html.is-scrolled) .site-header {
		background-color: rgb(255 255 255 / 0.75);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	/* Mobile panel: hidden until open */
	:global([data-nav-panel]) {
		display: none;
	}
	:global([data-nav-panel][data-state='open']) {
		display: block;
	}
	@media (min-width: 1024px) {
		:global([data-nav-panel]) {
			display: block;
		}
	}

	/* Desktop dropdown: hidden by default, shown when open */
	:global([data-dropdown]) {
		display: none;
		opacity: 0;
		transform: translateY(-4px);
	}
	:global([data-dropdown][data-open]) {
		display: block;
		opacity: 1;
		transform: translateY(0);
		transition: opacity 150ms ease-out, transform 150ms ease-out;
	}

	/* Compact-on-scroll (lg+): CSS transition only — no FLIP */
	@media (min-width: 1024px) {
		:global(.site-header) {
			height: 192px;
			overflow: visible;
			transition:
				height 450ms cubic-bezier(0.22, 1, 0.36, 1),
				background-color 200ms ease-out,
				backdrop-filter 200ms ease-out;
		}
		/* Clip overflow only during the height animation to prevent items
		   from escaping, but restore it so dropdowns can overflow the header. */
		:global(.site-header.is-animating) {
			overflow: hidden;
		}
		:global(html.is-scrolled) .site-header {
			height: 60px;
		}
		:global(.site-header-inner) {
			transition: padding 450ms cubic-bezier(0.22, 1, 0.36, 1);
		}
		:global(html.is-scrolled) .site-header-inner {
			padding-top: 1rem;
			padding-bottom: 1rem;
			align-items: center;
		}
	}

	/* Expanded state: right block width anchored to 75% column divider */
	@media (min-width: 1024px) {
		:global(html:not(.is-scrolled)) .site-header-inner > div:last-child {
			width: 25%;
			justify-content: space-between;
			padding-left: 1rem;
		}
	}
</style>

<script is:inline>
	(() => {
		const root = document.documentElement;
		const headerEl = document.querySelector('.site-header');

		// ── Scroll compact ──────────────────────────────────────────────────
		let isCompact = false;
		let transitionLock = false;
		const TRANSITION_MS = 460;

		const setCompact = (next) => {
			if (next === isCompact || transitionLock) return;
			transitionLock = true;
			setTimeout(() => { transitionLock = false; }, TRANSITION_MS);

			isCompact = next;
			root.classList.toggle('is-scrolled', next);

			// Temporarily add is-animating so overflow:hidden clips during
			// the height transition, then remove it so dropdowns can overflow.
			if (window.innerWidth >= 1024 && headerEl) {
				headerEl.classList.add('is-animating');
				setTimeout(() => headerEl.classList.remove('is-animating'), TRANSITION_MS);
			}
		};

		const updateScroll = () => setCompact(window.scrollY > 8);
		updateScroll();
		window.addEventListener('scroll', updateScroll, { passive: true });
		window.addEventListener('resize', updateScroll, { passive: true });

		// ── Desktop dropdown nav ─────────────────────────────────────────────
		let openCategoryId = null;
		let closeTimer = null;

		const getCategories = () =>
			Array.from(document.querySelectorAll('[data-desktop-category]'));

		const openDropdown = (catEl) => {
			if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
			const id = catEl.dataset.categoryId;
			if (openCategoryId === id) return;

			// Close existing
			if (openCategoryId) {
				const prev = document.querySelector(`[data-category-id="${openCategoryId}"]`);
				if (prev) _closeDropdown(prev);
			}

			openCategoryId = id;
			const trigger = catEl.querySelector('[data-category-trigger]');
			const dropdown = catEl.querySelector('[data-dropdown]');
			const icon = catEl.querySelector('[data-category-icon]');
			if (trigger) trigger.setAttribute('aria-expanded', 'true');
			if (icon) icon.classList.add('rotate-180');
			if (dropdown) dropdown.dataset.open = '';
		};

		const _closeDropdown = (catEl) => {
			const trigger = catEl.querySelector('[data-category-trigger]');
			const dropdown = catEl.querySelector('[data-dropdown]');
			const icon = catEl.querySelector('[data-category-icon]');
			if (trigger) trigger.setAttribute('aria-expanded', 'false');
			if (icon) icon.classList.remove('rotate-180');
			if (dropdown) delete dropdown.dataset.open;
		};

		const scheduleClose = (catEl) => {
			closeTimer = setTimeout(() => {
				const id = catEl.dataset.categoryId;
				if (openCategoryId === id) {
					_closeDropdown(catEl);
					openCategoryId = null;
				}
				closeTimer = null;
			}, 100);
		};

		const closeAll = () => {
			if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
			getCategories().forEach(_closeDropdown);
			openCategoryId = null;
		};

		getCategories().forEach((catEl) => {
			const trigger = catEl.querySelector('[data-category-trigger]');
			const dropdown = catEl.querySelector('[data-dropdown]');

			// Hover: open on mouseenter, schedule close on mouseleave
			catEl.addEventListener('mouseenter', () => openDropdown(catEl));
			catEl.addEventListener('mouseleave', () => scheduleClose(catEl));

			// Keep open if mouse re-enters dropdown
			if (dropdown) {
				dropdown.addEventListener('mouseenter', () => {
					if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
				});
				dropdown.addEventListener('mouseleave', () => scheduleClose(catEl));
			}

			// Click: toggle
			if (trigger) {
				trigger.addEventListener('click', (e) => {
					e.stopPropagation();
					const id = catEl.dataset.categoryId;
					if (openCategoryId === id) {
						closeAll();
					} else {
						openDropdown(catEl);
					}
				});
			}
		});

		// Close on click outside
		document.addEventListener('click', (e) => {
			if (!openCategoryId) return;
			const openCat = document.querySelector(`[data-category-id="${openCategoryId}"]`);
			if (openCat && openCat.contains(e.target)) return;
			closeAll();
		});

		// Close on Escape
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && openCategoryId) {
				const openCat = document.querySelector(`[data-category-id="${openCategoryId}"]`);
				const trigger = openCat && openCat.querySelector('[data-category-trigger]');
				closeAll();
				if (trigger) trigger.focus();
			}
		});

		// ── Mobile nav ────────────────────────────────────────────────────────
		const panel = document.querySelector('[data-nav-panel]');
		const toggle = document.querySelector('[data-nav-toggle]');
		const navIcon = document.querySelector('[data-nav-icon]');
		const navLabel = document.querySelector('[data-nav-label]');

		if (toggle && panel) {
			const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

			const setOpen = (open) => {
				toggle.setAttribute('aria-expanded', String(open));
				panel.dataset.state = open ? 'open' : 'closed';
				if (navIcon) navIcon.classList.toggle('rotate-180', open);
				if (navLabel) navLabel.textContent = open ? 'Close' : 'Menu';
				// Collapse all accordion sections when menu closes
				if (!open) collapseAllMobile();
			};

			toggle.addEventListener('click', () => setOpen(!isOpen()));

			// Close menu when a nav link is tapped
			panel.querySelectorAll('[data-nav-link]').forEach((a) => {
				a.addEventListener('click', () => setOpen(false));
			});

			// Close on click outside
			document.addEventListener('click', (e) => {
				if (!isOpen()) return;
				if (panel.contains(e.target) || toggle.contains(e.target)) return;
				setOpen(false);
			});

			// Close on Escape
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && isOpen()) {
					setOpen(false);
					toggle.focus();
				}
			});
		}

		// ── Mobile accordion ─────────────────────────────────────────────────
		const getMobileCategories = () =>
			Array.from(document.querySelectorAll('[data-mobile-category]'));

		const collapseAllMobile = () => {
			getMobileCategories().forEach((catEl) => {
				const mPanel = catEl.querySelector('[data-mobile-panel]');
				const mTrigger = catEl.querySelector('[data-mobile-trigger]');
				const mIcon = catEl.querySelector('[data-mobile-icon]');
				if (mPanel) mPanel.style.maxHeight = '0';
				if (mTrigger) mTrigger.setAttribute('aria-expanded', 'false');
				if (mIcon) mIcon.classList.remove('rotate-180');
			});
		};

		getMobileCategories().forEach((catEl) => {
			const mTrigger = catEl.querySelector('[data-mobile-trigger]');
			const mPanel = catEl.querySelector('[data-mobile-panel]');
			const mIcon = catEl.querySelector('[data-mobile-icon]');

			if (!mTrigger || !mPanel) return;

			mTrigger.addEventListener('click', () => {
				const isExpanded = mTrigger.getAttribute('aria-expanded') === 'true';

				if (isExpanded) {
					// Collapse this section
					mPanel.style.maxHeight = '0';
					mTrigger.setAttribute('aria-expanded', 'false');
					if (mIcon) mIcon.classList.remove('rotate-180');
				} else {
					// Collapse siblings, expand this one
					getMobileCategories().forEach((sibling) => {
						if (sibling === catEl) return;
						const sibPanel = sibling.querySelector('[data-mobile-panel]');
						const sibTrigger = sibling.querySelector('[data-mobile-trigger]');
						const sibIcon = sibling.querySelector('[data-mobile-icon]');
						if (sibPanel) sibPanel.style.maxHeight = '0';
						if (sibTrigger) sibTrigger.setAttribute('aria-expanded', 'false');
						if (sibIcon) sibIcon.classList.remove('rotate-180');
					});

					mPanel.style.maxHeight = mPanel.scrollHeight + 'px';
					mTrigger.setAttribute('aria-expanded', 'true');
					if (mIcon) mIcon.classList.add('rotate-180');
				}
			});
		});
	})();
</script>
