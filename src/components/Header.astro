---
import { Image } from 'astro:assets';
import emblemInk from '../assets/images/emblem-ink.svg';
import { GIVE_URL } from '../lib/links';

const navItems = [
	{ marker: 'I.',    label: 'Our Vision',   href: '/our-vision' },
	{ marker: 'II.',   label: 'How It Works', href: '/how-it-works' },
	{ marker: 'III.',  label: 'People',       href: '/people' },
	{ marker: 'IV.',   label: 'Admissions',   href: '/admissions' },
	{ marker: 'V.',    label: 'Give',         href: GIVE_URL },
];

// Show a dedicated "← Home" link on every page except the home page.
// The wordmark and emblem both link to `/` but the convention isn't
// obvious enough for every visitor — this gives them an unmistakable
// back-to-home button.
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHomePage = currentPath === '/';
---

<!--
	Top header bar.
	`sticky top-0` keeps it pinned to the top of the viewport while the user
	scrolls. Placed at the Layout root (sibling of all canvas wrappers and
	full-bleed sections), so it stays pinned across every section and only
	un-sticks at the very bottom of the document.

	The outer `<header>` spans the viewport width so the frosted background
	can bleed full-width; the inner `<div class="site-header-inner">` is
	constrained to `max-w-canvas` so the wordmark/nav/emblem stay aligned
	with the rest of the page grid.

	At scrollY=0 the header is fully transparent so the page-wide vertical
	column lines remain visible all the way to the top edge. As soon as the
	user scrolls (handled by the inline script below toggling
	`html.is-scrolled`), the header gains a frosted `bg-white/75 backdrop-blur-md`
	treatment so content sliding underneath stays legible behind it. The
	transition is short and eased.

	`z-40` keeps it above page content but below any future modal layer.
-->
<header class="site-header sticky top-0 z-40 bg-transparent transition-[background-color,backdrop-filter] duration-200 ease-out">
	<div class="site-header-inner mx-auto flex w-full max-w-canvas items-center justify-between px-6 pb-7 pt-7 sm:px-10 sm:pb-8 sm:pt-8 lg:items-start lg:px-12 lg:pb-9 lg:pt-9">
	<div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-6">
		<a
			href="/"
			aria-label="Trinity Classical Academy"
			class="font-sans text-[12px] font-medium uppercase tracking-eyebrow text-ink"
		>
			Trinity Classical Academy
		</a>

		{!isHomePage && (
			<a
				href="/"
				class="group inline-flex items-center gap-1.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink-soft transition-colors hover:text-forest"
				aria-label="Back to home"
			>
				<span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
				<span>Home</span>
			</a>
		)}
	</div>

	<div class="relative flex items-center gap-4 sm:gap-6 lg:items-start lg:gap-12">
		<!--
			Mobile-only disclosure button.
			On < lg the primary nav is collapsed by default; this button
			expands it into a frosted dropdown anchored below the header.
			Hidden on lg+, where the nav is always visible inline.
		-->
		<button
			type="button"
			aria-expanded="false"
			aria-controls="primary-nav"
			class="flex items-center gap-1.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink transition-colors hover:text-forest lg:hidden"
			data-nav-toggle
		>
			<span data-nav-label>Menu</span>
			<svg
				width="10"
				height="10"
				viewBox="0 0 10 10"
				class="transition-transform duration-150 ease-out"
				data-nav-icon
				aria-hidden="true"
			>
				<path
					d="M2 3.5 L5 6.5 L8 3.5"
					stroke="currentColor"
					stroke-width="1.5"
					fill="none"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		</button>

		<nav
			id="primary-nav"
			aria-label="Primary"
			data-nav-panel
			data-state="closed"
			class="absolute right-0 top-full mt-3 min-w-[180px] rounded-card border border-ink/10 bg-white/95 p-5 shadow-lg backdrop-blur-md lg:relative lg:right-auto lg:top-auto lg:mt-0 lg:min-w-0 lg:rounded-none lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-none"
		>
			<ol class="flex flex-col gap-1.5">
				{navItems.map((item) => (
					<li class="flex h-5 items-center gap-3">
						<span class="w-6 font-mono text-[10px] leading-none text-ink-mute">
							{item.marker}
						</span>
						<a
							href={item.href}
							class="font-sans text-sm leading-none text-ink transition hover:text-forest"
						>
							{item.label}
						</a>
					</li>
				))}
			</ol>
		</nav>

		<a
			href="/"
			aria-label="Trinity Classical Academy"
			class="text-ink"
		>
			<Image
				src={emblemInk}
				alt=""
				class="h-9 w-auto"
			/>
		</a>
	</div>
	</div>
</header>

<style>
	/* Frosted backdrop activates only when the page has been scrolled.
	   At scrollY=0 the header is fully transparent so the page-wide column
	   lines remain visible all the way to the top of the viewport. */
	:global(html.is-scrolled) .site-header {
		background-color: rgb(255 255 255 / 0.75);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	/* Mobile primary-nav disclosure: collapsed by default, expanded on
	   data-state="open". On lg+ the panel is always visible inline.
	   `:global()` is required so Astro's scoped-style hashing doesn't
	   prevent the attribute selector from matching the live nav element. */
	:global([data-nav-panel]) {
		display: none;
	}
	:global([data-nav-panel][data-state='open']) {
		display: block;
	}
	@media (min-width: 1024px) {
		:global([data-nav-panel]) {
			display: block;
		}
	}

	/* ===== Compact-on-scroll header (lg+) =====
	   When the page is scrolled (`html.is-scrolled`), shrink the header
	   padding and collapse the vertical Roman-numeral nav into a single
	   horizontal row. The smooth slide-into-place animation is handled
	   in JS by the FLIP technique with staggered transition delays.

	   Height lives on the outer `.site-header`; padding + alignment live
	   on the canvas-constrained `.site-header-inner` so the header bleeds
	   full-width visually but the content stays on the canvas grid.

	   `overflow: hidden` on the outer prevents items from visually escaping
	   during the height interpolation. */
	@media (min-width: 1024px) {
		:global(.site-header) {
			height: 192px;
			overflow: hidden;
			transition:
				height 450ms cubic-bezier(0.22, 1, 0.36, 1),
				background-color 200ms ease-out,
				backdrop-filter 200ms ease-out;
		}
		:global(html.is-scrolled) .site-header {
			height: 60px;
		}
		:global(.site-header-inner) {
			transition: padding 450ms cubic-bezier(0.22, 1, 0.36, 1);
		}
		:global(html.is-scrolled) .site-header-inner {
			padding-top: 1rem;
			padding-bottom: 1rem;
			align-items: center;
		}
		:global(html.is-scrolled) .site-header-inner > div:last-of-type {
			align-items: center;
		}
		:global(html.is-scrolled) .site-header-inner [data-nav-panel] ol {
			flex-direction: row;
			align-items: center;
			gap: 1.75rem;
		}
		/* Hide Roman-numeral markers in compact mode */
		:global(html.is-scrolled) .site-header-inner [data-nav-panel] ol > li > span:first-child {
			display: none;
		}
	}

	/* ===== Anchor the expanded nav to the 75% vertical divider =====
	   At lg+ when the header is NOT scrolled, lock the right block
	   (nav + emblem) to exactly 25% of the site-header-inner content
	   box. Because the vertical dividers live inside the same
	   `lg:px-12` content area, a 25%-wide right block aligned to the
	   right edge of that content area places its own left edge
	   exactly on the 75% divider line. The 16px padding-left then
	   pushes the Roman numerals 16px inward from the line, matching
	   the padding the hero body column uses below. */
	@media (min-width: 1024px) {
		:global(html:not(.is-scrolled)) .site-header-inner > div:last-child {
			width: 25%;
			justify-content: space-between;
			padding-left: 1rem;
		}
	}
</style>

<script is:inline>
	(() => {
		const root = document.documentElement;
		const panel = document.querySelector('[data-nav-panel]');
		const navItems = panel ? Array.from(panel.querySelectorAll('li')) : [];
		const headerEl = document.querySelector('.site-header');

		// Track current compact state so we only run FLIP on actual transitions
		let isCompact = false;
		// Guard that ignores state changes while the CSS height transition
		// is in flight (450ms). Without this, a reflow-triggered scroll
		// adjustment mid-transition can flip us back to the previous state
		// and the two states oscillate indefinitely.
		let transitionLock = false;
		const TRANSITION_MS = 460;

		// FLIP transition: capture old layout positions, snap to the new
		// layout via class change, then animate each item from its old
		// position back to its new position with a staggered delay so the
		// items appear to slide one after another into the compact row.
		const setCompact = (next) => {
			if (next === isCompact || transitionLock) return;
			transitionLock = true;
			setTimeout(() => { transitionLock = false; }, TRANSITION_MS);
			// FLIP only on lg+; on mobile the layout is the disclosure
			// dropdown and there's nothing to animate.
			if (window.innerWidth < 1024 || navItems.length === 0) {
				isCompact = next;
				root.classList.toggle('is-scrolled', next);
				return;
			}

			// First — read positions BEFORE the layout change.
			const firstItem = navItems.map((el) => el.getBoundingClientRect());
			const firstHeader = headerEl?.getBoundingClientRect();

			// Last — apply the new layout.
			isCompact = next;
			root.classList.toggle('is-scrolled', next);

			// Force the browser to lay out the new state synchronously.
			void document.body.offsetHeight;

			const lastItem = navItems.map((el) => el.getBoundingClientRect());
			const lastHeader = headerEl?.getBoundingClientRect();

			// Account for the fact that the header itself moves (its padding
			// shrinks). The container shift would otherwise double-count when
			// we compute item deltas.
			const headerDx = firstHeader && lastHeader ? firstHeader.left - lastHeader.left : 0;
			const headerDy = firstHeader && lastHeader ? firstHeader.top - lastHeader.top : 0;

			// Invert + Play, with a stagger so items move sequentially.
			navItems.forEach((el, i) => {
				const dx = firstItem[i].left - lastItem[i].left - headerDx;
				const dy = firstItem[i].top - lastItem[i].top - headerDy;
				if (Math.abs(dx) < 0.5 && Math.abs(dy) < 0.5) return;

				// Order the stagger so item closest to the destination
				// (top of the row) moves first when expanding/collapsing.
				const delay = next ? i * 60 : (navItems.length - 1 - i) * 60;

				el.style.transition = 'none';
				el.style.transform = `translate(${dx}px, ${dy}px)`;
				// Force reflow so the inverse transform is committed before
				// the easing transition is applied.
				void el.offsetHeight;
				el.style.transition = `transform 450ms cubic-bezier(0.22, 1, 0.36, 1) ${delay}ms`;
				el.style.transform = '';

				// Scrub any leftover inline styles after the transition
				// settles so no sub-pixel residue remains to misalign
				// items in the final layout.
				const cleanup = () => {
					el.style.transition = '';
					el.style.transform = '';
					el.removeEventListener('transitionend', cleanup);
				};
				el.addEventListener('transitionend', cleanup);
			});
		};

		const updateScroll = () => setCompact(window.scrollY > 8);
		updateScroll();
		window.addEventListener('scroll', updateScroll, { passive: true });
		// Resync if the viewport crosses the lg breakpoint
		window.addEventListener('resize', updateScroll, { passive: true });

		// Mobile nav disclosure
		const toggle = document.querySelector('[data-nav-toggle]');
		const icon = document.querySelector('[data-nav-icon]');
		const label = document.querySelector('[data-nav-label]');
		if (toggle && panel) {
			const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';
			const setOpen = (open) => {
				toggle.setAttribute('aria-expanded', String(open));
				panel.dataset.state = open ? 'open' : 'closed';
				if (icon) icon.classList.toggle('rotate-180', open);
				if (label) label.textContent = open ? 'Close' : 'Menu';
			};
			toggle.addEventListener('click', () => setOpen(!isOpen()));
			// Close after a nav link is followed
			panel.querySelectorAll('a').forEach((a) => {
				a.addEventListener('click', () => setOpen(false));
			});
			// Close on click outside the panel/toggle
			document.addEventListener('click', (e) => {
				if (!isOpen()) return;
				const target = e.target;
				if (panel.contains(target) || toggle.contains(target)) return;
				setOpen(false);
			});
			// Close on Escape
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && isOpen()) setOpen(false);
			});
		}
	})();
</script>
