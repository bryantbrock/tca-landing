---
import { INTERVIEW_URL, TEACHER_APP_URL } from '../lib/links';
---

<!-- Hero content.
     Headline uses clamp(45px, 10vw, 150px) so type growth tracks the
     viewport up to ~1500px and then locks at 150px — just past the
     1440px canvas max. Beyond that, the canvas is centered and the
     headline stays proportional instead of ballooning on ultrawide
     monitors.

     Hero parent height uses 28.5vw (≈ 2.85× the 10vw font-size) with a
     330px floor and a cap of 428px (2.85 × 150) so height locks in
     lockstep with the headline when the viewport exceeds ~1500px. -->
<div class="relative mt-12 sm:mt-16 lg:mt-20 lg:h-[clamp(330px,28.5vw,428px)]">
	<h1
		class="px-6 font-display uppercase leading-[0.95] tracking-tight text-ink sm:px-10 lg:px-12"
	>
		<span class="block text-[clamp(45px,10vw,150px)]">Truth.</span>
		<span class="block text-[clamp(45px,10vw,150px)]">Goodness.</span>
		<span class="block text-[clamp(45px,10vw,150px)]">Beauty.</span>
	</h1>

	<!-- Right column: anchored to the 75% vertical divider at all lg+
	     widths. Uses left + right positioning so the column width scales
	     automatically (~216px at 1024 → ~320px at 1440). Text steps
	     down to 16px at lg to fit the narrower column, then back to 18px
	     at xl where there's more room. -->
	<div
		class="mt-10 px-6 sm:px-10 lg:absolute lg:left-[calc(75%-8px)] lg:right-12 lg:top-[clamp(60px,9vw,135px)] lg:mt-0 lg:px-0"
	>
		<p
			class="font-sans text-[18px] font-semibold leading-[1.2] tracking-[-0.01em] text-ink-soft lg:text-base xl:text-[18px]"
		>
			<strong class="font-semibold text-ink">Trinity Classical Academy</strong>
			is an ACCS-mentored classical Christian school in Birmingham, Alabama, under the care of Trinity Presbyterian Church (CREC). Opening Fall 2026 for grades K–8.
		</p>
		<div class="mt-6 flex flex-col items-start gap-3 lg:mt-4 xl:mt-6">
			<a
				href={INTERVIEW_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="whitespace-nowrap rounded-pill bg-gold px-6 py-2.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink transition hover:bg-gold-hover"
			>
				Request an Interview
			</a>
			<a
				href={TEACHER_APP_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="whitespace-nowrap font-mono text-xs font-medium uppercase tracking-eyebrow text-ink-mute transition hover:text-forest"
			>
				Apply to Teach →
			</a>
		</div>
	</div>
</div>
