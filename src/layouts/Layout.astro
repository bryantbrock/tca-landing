---
import '../styles/global.css';
import '@fontsource/geist-sans/latin-400.css';
import '@fontsource/geist-sans/latin-500.css';
import '@fontsource/geist-sans/latin-600.css';
import '@fontsource/geist-sans/latin-700.css';
// Martina Plantijn is self-hosted via @font-face in global.css
import '@fontsource/ibm-plex-mono/latin-400.css';
import '@fontsource/ibm-plex-mono/latin-500.css';

// Preload critical fonts to eliminate the FOUT (Flash of Unstyled Text)
// on first paint. Vite's `?url` transform bundles them into /_astro/*.woff2
// with hashed filenames, and the preload <link> tags in the head below
// start the download as soon as the HTML is parsed (in parallel with CSS).
import geistRegular from '@fontsource/geist-sans/files/geist-sans-latin-400-normal.woff2?url';
import geistSemibold from '@fontsource/geist-sans/files/geist-sans-latin-600-normal.woff2?url';
import martinaLight from '../assets/fonts/MartinaPlantijn-Light.woff2?url';
import martinaLightItalic from '../assets/fonts/MartinaPlantijn-LightItalic.woff2?url';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogType?: string;
	canonicalPath?: string;
	noindex?: boolean;
}

const {
	title,
	description,
	ogImage = '/og-image.png',
	ogTitle,
	ogDescription,
	ogType = 'website',
	canonicalPath,
	noindex = false,
} = Astro.props;

const origin = Astro.site ?? Astro.url;
const absolute = (path: string) => new URL(path, origin).href;
const canonical =
	canonicalPath !== undefined
		? new URL(canonicalPath, origin).href
		: new URL(Astro.url.pathname, origin).href;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const ogImageUrl = absolute(ogImage);

// Structured data: schema.org EducationalOrganization
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'EducationalOrganization',
	name: 'Trinity Classical Academy',
	description:
		'Trinity Classical Academy partners with families in the joyful discipleship of students through rigorous, Christ-centered classical education.',
	url: 'https://trinityclassical.academy',
	logo: 'https://trinityclassical.academy/favicon-192.png',
	email: 'info@trinityclassical.academy',
	address: {
		'@type': 'PostalAddress',
		streetAddress: '7160 Cahaba Valley Rd.',
		addressLocality: 'Birmingham',
		addressRegion: 'AL',
		postalCode: '35242',
		addressCountry: 'US',
	},
	parentOrganization: {
		'@type': 'Church',
		name: 'Trinity Presbyterian Church',
	},
	sameAs: [
		'https://instagram.com/trinityclassicalacademy',
	],
};
---

<!doctype html>
<html lang="en" class="bg-canvas text-ink antialiased">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Preload above-the-fold fonts to eliminate FOUT on first paint -->
		<link rel="preload" href={geistRegular} as="font" type="font/woff2" crossorigin="anonymous" />
		<link rel="preload" href={geistSemibold} as="font" type="font/woff2" crossorigin="anonymous" />
		<link rel="preload" href={martinaLight} as="font" type="font/woff2" crossorigin="anonymous" />
		<link rel="preload" href={martinaLightItalic} as="font" type="font/woff2" crossorigin="anonymous" />
		<meta name="generator" content={Astro.generator} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={resolvedOgTitle} />
		<meta property="og:description" content={resolvedOgDescription} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={resolvedOgTitle} />
		<meta name="twitter:description" content={resolvedOgDescription} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Structured data: schema.org EducationalOrganization -->
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

		<!-- Analytics: add a script tag here when an analytics provider is chosen.
		     The Cloudflare Web Analytics beacon was removed pre-launch — swap in
		     Netlify Analytics, Plausible, Umami, or similar when ready. -->
	</head>
	<body class="min-h-screen bg-canvas font-sans text-ink antialiased">
		<slot />
	</body>
</html>
