---
import Layout from '../layouts/Layout.astro';

const title = 'Page not found — TCA';
const description = 'The page you requested does not exist.';
---

<Layout {title} {description} noindex>
	<section
		class="mx-auto flex min-h-[50vh] max-w-5xl flex-col items-center justify-center px-4 py-16 text-center sm:px-6"
	>
		<h1 class="font-display text-4xl font-semibold">404</h1>
		<p class="mt-3 text-muted">This page does not exist.</p>
		<p class="mt-8">
			<a
				href="/"
				class="font-medium text-foreground underline decoration-muted underline-offset-4 transition hover:decoration-foreground"
			>
				Back to home
			</a>
		</p>
	</section>
</Layout>
