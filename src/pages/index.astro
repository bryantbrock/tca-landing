---
import Layout from '../layouts/Layout.astro';

const title = 'TCA — coming soon';
const description =
	'Placeholder site for TCA. Full content is on the way.';
---

<Layout {title} {description}>
	<section
		class="mx-auto flex min-h-[60vh] max-w-5xl flex-col items-center justify-center px-4 py-16 text-center sm:px-6"
	>
		<h1 class="font-display text-4xl font-semibold tracking-wide sm:text-5xl">
			TCA
		</h1>
		<p class="mt-4 max-w-md text-muted">
			Placeholder — site under construction.
		</p>
	</section>
</Layout>
