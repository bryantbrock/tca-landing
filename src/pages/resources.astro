---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CLASSREACH_URL } from '../lib/links';

const title = 'Resources — Trinity Classical Academy';
const description =
	'Policies, FAQs, and reference material for current and prospective families at Trinity Classical Academy.';

const resources = [
	{
		label: 'PARENT PORTAL',
		title: 'ClassReach Login',
		description: 'Access the parent and student portal to view grades, attendance, announcements, and account information.',
		href: CLASSREACH_URL,
		external: true,
		cta: 'Log in to ClassReach',
	},
	{
		label: 'POLICY DOCUMENT',
		title: 'Tuition & Fee Policy',
		description: 'A complete overview of tuition, enrollment fees, and payment schedules for the upcoming school year.',
		href: '/resources/tuition',
		external: false,
		cta: 'Read the policy',
	},
	{
		label: 'CALENDAR',
		title: 'School Calendar 2026–2027',
		description: 'The academic calendar for the upcoming school year, including key dates, breaks, and start/end dates.',
		href: '/TCA-Calendar-2026-2027.pdf',
		external: true,
		cta: 'Download the calendar',
	},
	{
		label: 'POLICY DOCUMENT',
		title: 'Uniform Policy',
		description: 'Details on the required uniform for all students, including approved vendors and dress code guidelines.',
		href: '/resources/uniform',
		external: false,
		cta: 'Read the policy',
	},
	{
		label: 'REFERENCE',
		title: 'Frequently Asked Questions',
		description: 'Answers to the questions we hear most from prospective families — location, grades, accreditation, homework, and more.',
		href: '/faq',
		external: false,
		cta: 'View the FAQ',
	},
	{
		label: 'CAREERS',
		title: 'Join Our Faculty',
		description: "We're actively hiring founding faculty. Learn about who we're looking for and how to apply.",
		href: '/careers',
		external: false,
		cta: 'Learn more',
	},
];
---

<Layout {title} {description}>
	<Header />

	<div class="relative mx-auto w-full max-w-canvas flow-root">
		<div
			class="pointer-events-none absolute -top-[192px] bottom-0 left-0 right-0 z-0 hidden lg:block lg:px-12"
			aria-hidden="true"
		>
			<div class="relative h-full">
				<div class="absolute inset-y-0 left-1/4 w-px bg-ink/[0.04]"></div>
				<div class="absolute inset-y-0 left-1/2 w-px bg-ink/[0.04]"></div>
				<div class="absolute inset-y-0 left-3/4 w-px bg-ink/[0.04]"></div>
			</div>
		</div>

		<!-- ====== HERO ====== -->
		<section
			id="resources-hero"
			aria-labelledby="resources-heading"
			class="relative z-10 px-6 pb-0 pt-20 sm:px-10 sm:pt-28 lg:px-12 lg:pt-36"
		>
			<p class="font-mono text-xs font-medium uppercase tracking-eyebrow text-forest">
				Resources
			</p>

			<h1
				id="resources-heading"
				class="mt-8 font-display italic leading-[0.95] tracking-tight text-ink"
				style="font-size: clamp(72px, 12vw, 160px);"
			>
				Policies, fees,<br />and answers.
			</h1>

			<div class="mt-12 lg:w-1/2 lg:pr-12">
				<p class="font-sans text-[18px] font-semibold leading-[1.2] tracking-[-0.01em] text-ink-soft">
					Reference material for current and prospective families. Policies, answers to common questions, and information about joining our faculty.
				</p>
			</div>
		</section>

		<!-- ====== RESOURCE GRID ====== -->
		<section
			id="resource-list"
			aria-labelledby="resource-list-heading"
			class="relative z-10 px-6 pb-32 pt-24 sm:px-10 sm:pb-40 sm:pt-32 lg:px-12 lg:pb-48 lg:pt-40"
		>
			<div class="flex flex-col gap-12 lg:flex-row lg:gap-0">
				<div class="shrink-0 lg:w-1/4 lg:pr-8 lg:pt-1">
					<p
						id="resource-list-heading"
						class="font-mono text-xs font-medium uppercase tracking-eyebrow text-forest"
					>
						All Resources
					</p>
				</div>

				<div class="min-w-0 flex-1 lg:pl-8">
					<div class="grid grid-cols-1 gap-0 sm:grid-cols-2">
						{resources.map((resource, index) => (
							<a
								href={resource.href}
								{...(resource.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
								class="group flex flex-col gap-3 py-10 pr-8 transition"
							>
								<div class="flex items-center gap-3">
									<p class="font-mono text-[10px] font-medium uppercase tracking-eyebrow text-ink-mute">
										{resource.label}
									</p>
									{resource.external && (
										<p class="font-mono text-[10px] font-medium uppercase tracking-eyebrow text-ink-mute opacity-60">
											External
										</p>
									)}
								</div>

								<h2 class="font-display text-[28px] leading-[1.1] text-ink transition group-hover:text-forest sm:text-[32px]">
									{resource.title}
									{resource.external && (
										<span class="ml-1 inline-block text-[20px] not-italic align-middle text-ink-mute opacity-60">↗</span>
									)}
								</h2>

								<p class="font-sans text-base leading-snug text-ink-soft">
									{resource.description}
								</p>

								<p class="mt-2 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-forest transition group-hover:opacity-70">
									{resource.cta} →
								</p>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
	</div>

	<Footer />
</Layout>
