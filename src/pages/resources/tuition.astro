---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Tuition & Fee Policy — Trinity Classical Academy';
const description =
	'A complete overview of tuition, enrollment fees, and payment schedules for Trinity Classical Academy.';

// Issuu flipbook published by concordiseducationpartners.
//
// IMPORTANT: must use the `e.issuu.com` subdomain — the bare
// `issuu.com/embed.html` endpoint sends `X-Frame-Options: SAMEORIGIN`
// which blocks third-party iframe embedding entirely. `e.issuu.com` is
// Issuu's dedicated embed subdomain that omits that header (this is
// the same approach Squarespace uses).
//
// The publication was embedded in the original Squarespace site with
// only the internal pubId hash exposed (no human-readable document
// slug), so the embed URL and the "View fullscreen" URL are the same
// renderer endpoint.
const issuuEmbedUrl =
	'https://e.issuu.com/embed.html?backgroundColor=%23dadada&pubId=c9ee76dac49eb9ec373f369b391aa6cd';
const issuuFullscreenUrl = issuuEmbedUrl;
---

<Layout {title} {description}>
	<Header />

	<div class="relative mx-auto w-full max-w-canvas flow-root">
		<!-- Page-wide vertical column dividers, matching every other inner page. -->
		<div
			class="pointer-events-none absolute -top-[192px] bottom-0 left-0 right-0 z-0 hidden lg:block lg:px-12"
			aria-hidden="true"
		>
			<div class="relative h-full">
				<div class="absolute inset-y-0 left-1/4 w-px bg-ink/[0.04]"></div>
				<div class="absolute inset-y-0 left-1/2 w-px bg-ink/[0.04]"></div>
				<div class="absolute inset-y-0 left-3/4 w-px bg-ink/[0.04]"></div>
			</div>
		</div>

		<!-- ====== HERO ====== -->
		<section
			id="tuition-hero"
			aria-labelledby="tuition-heading"
			class="relative z-10 px-6 pb-0 pt-20 sm:px-10 sm:pt-28 lg:px-12 lg:pt-36"
		>
			<!-- Editorial breadcrumb back to the parent index. Sits above the
			     eyebrow so the topical label still leads the headline visually. -->
			<a
				href="/resources"
				class="inline-flex items-center gap-1.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink-mute transition hover:text-forest"
			>
				<span aria-hidden="true">←</span>
				<span>Resources</span>
			</a>

			<p class="mt-8 font-mono text-xs font-medium uppercase tracking-eyebrow text-forest">
				Policy Document
			</p>

			<h1
				id="tuition-heading"
				class="mt-8 font-display italic leading-[0.95] tracking-tight text-ink"
				style="font-size: clamp(60px, 10vw, 140px);"
			>
				Tuition &amp;<br />fee policy.
			</h1>

			<div class="mt-12 max-w-[640px]">
				<p class="font-sans text-[18px] font-semibold leading-[1.2] tracking-[-0.01em] text-ink-soft">
					A complete overview of tuition, enrollment fees, and payment
					schedules for the upcoming school year. Flip through below or
					open the full document on Issuu.
				</p>
			</div>
		</section>

		<!-- ====== PAYMENT SUMMARY ====== -->
		<section
			aria-label="Payment summary"
			class="relative z-10 px-6 pb-0 pt-12 sm:px-10 sm:pt-16 lg:px-12 lg:pt-20"
		>
			<div class="max-w-[640px]">
				<p class="font-mono text-xs font-medium uppercase tracking-eyebrow text-forest">
					Key dates &amp; options
				</p>
				<p class="mt-6 font-sans text-base leading-snug text-ink-soft">
					Families may pay tuition in full, biannually, or monthly. Here are the
					essential details for the upcoming school year:
				</p>
				<ul class="mt-4 flex flex-col gap-3">
					<li class="flex gap-3 font-sans text-base leading-snug text-ink-soft">
						<span class="mt-1 shrink-0 text-forest">—</span>
						<span><strong class="font-semibold text-ink">First payment due May 1.</strong> This applies to all payment plans.</span>
					</li>
					<li class="flex gap-3 font-sans text-base leading-snug text-ink-soft">
						<span class="mt-1 shrink-0 text-forest">—</span>
						<span><strong class="font-semibold text-ink">$200 discount for payment in full by May 1.</strong> Pay the full year's tuition by that date and the discount is automatically applied.</span>
					</li>
					<li class="flex gap-3 font-sans text-base leading-snug text-ink-soft">
						<span class="mt-1 shrink-0 text-forest">—</span>
						<span><strong class="font-semibold text-ink">Payment options:</strong> full pay (by May 1), biannual (two installments), or monthly. Details for each plan are in the policy document below.</span>
					</li>
				</ul>
			</div>
		</section>

		<!-- ====== FLIPBOOK ====== -->
		<section
			aria-labelledby="tuition-flipbook-heading"
			class="relative z-10 px-6 pb-24 pt-16 sm:px-10 sm:pb-32 sm:pt-20 lg:px-12 lg:pb-40 lg:pt-24"
		>
			<h2 id="tuition-flipbook-heading" class="sr-only">Flipbook viewer</h2>

			<!-- Iframe frame.
			     Aspect ratios shift across breakpoints because Issuu's embed
			     renders a single portrait page on narrow viewports and a
			     two-page landscape spread on wide ones. The max-w cap keeps
			     the spread from getting absurdly tall at xl+. -->
			<div class="mx-auto max-w-[1120px]">
				<div
					class="relative aspect-[3/4] w-full overflow-hidden rounded-card border border-ink/10 bg-white shadow-2xl sm:aspect-[4/3] lg:aspect-[16/10]"
				>
					<iframe
						src={issuuEmbedUrl}
						title="Trinity Classical Academy — Tuition & Fee Policy"
						loading="lazy"
						allow="clipboard-write; fullscreen"
						allowfullscreen
						sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox allow-forms allow-modals allow-downloads allow-top-navigation-by-user-activation"
						class="absolute inset-0 h-full w-full border-0"
					></iframe>
				</div>

				<!-- Action row: primary fullscreen CTA + tertiary back link. -->
				<div class="mt-10 flex flex-col items-center gap-4">
					<a
						href={issuuFullscreenUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-pill bg-gold px-6 py-2.5 font-mono text-[11px] font-medium uppercase tracking-eyebrow text-ink transition hover:opacity-90"
					>
						View Fullscreen ↗
					</a>
					<a
						href="/resources"
						class="font-mono text-[10px] font-medium uppercase tracking-eyebrow text-ink-mute transition hover:text-forest"
					>
						← Back to all resources
					</a>
				</div>
			</div>
		</section>
	</div>

	<Footer />
</Layout>
